<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Кофейня Sweet Coffee</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Шапка сайта -->
    <header>
        <h1>☕ Sweet Coffee</h1>
        <p>Уютная кофейня с ароматом счастья</p>
    </header>

    <!-- Навигация -->
    <nav>
        <a href="#coffee">Кофе</a>
        <a href="#desserts">Десерты</a>
        <a href="#discount">Скидки</a>
        <a href="#contact">Контакты</a>
    </nav>

    <!-- Раздел Кофе -->
    <section id="coffee">
        <h2>Наш кофе</h2>

        <div class="products">

            <!-- Карточка товара -->
            <div class="card">
                <!-- Место для изображения -->
                <img src="https://i.pinimg.com/1200x/71/4a/0e/714a0ebc8380815fa250efa145be0b00.jpg" class="img">
                <h3>Латте</h3>
                <p>Нежный кофе с молочной пенкой</p>
                <span class="price">120 сом</span>
            </div>

            <div class="card">
                <img src="https://i.pinimg.com/736x/4d/e4/0c/4de40c8bbd7ca5c9a76587faf386d444.jpg" class="img">
                <h3>Капучино</h3>
                <p>Классический вкус Италии</p>
                <span class="price">110 сом</span>
            </div>

            <div class="card">
                <img src="https://i.pinimg.com/736x/e8/8c/96/e88c963b93c4ee2f3481b3576e2c9395.jpg" class="img">
                <h3>Эспрессо</h3>
                <p>Крепкий и бодрящий</p>
                <span class="price">90 сом</span>
            </div>

        </div>
    </section>

    <!-- Раздел Десерты -->
    <section id="desserts">
        <h2>Десерты</h2>

        <div class="products">

            <div class="card">
                <img src="https://i.pinimg.com/736x/50/c1/72/50c172766cd6a43658484a72ce0a5a3a.jpg" class="img">
                <h3>Чизкейк</h3>
                <p>Сливочный классический десерт</p>
                <span class="price">150 сом</span>
            </div>

            <div class="card">
                <img src="https://i.pinimg.com/736x/65/93/ef/6593efb114d57d2bb8c195acd701af02.jpg" class="img">
                <h3>Круассан</h3>
                <p>Свежая французская выпечка</p>
                <span class="price">80 сом</span>
            </div>

        </div>
    </section>

    <!-- Скидочный раздел -->
    <section id="discount">
        <h2>🔥 Скидки</h2>

        <div class="products">

            <div class="card discount-card">
                <img src="https://i.pinimg.com/1200x/90/46/2b/90462b195893a4d36f8deb2888080d20.jpg" class="img">
                <h3>Мокка</h3>
                <p>Шоколадный кофе</p>
                <span class="old-price">140 сом</span>
                <span class="price">110 сом</span>
            </div>

            <div class="card discount-card">
                <img src="https://i.pinimg.com/1200x/57/bd/7d/57bd7d016b022bfab87ae7a454b74191.jpg" class="img">
                <h3>Американо</h3>
                <p>Лёгкий и насыщенный</p>
                <span class="old-price">100 сом</span>
                <span class="price">75 сом</span>
            </div>

            <div class="card discount-card">
                <img src="https://i.pinimg.com/736x/83/25/02/83250237c079b3502020070dcc19ec02.jpg" class="img">
                <h3>Маффин</h3>
                <p>С шоколадной начинкой</p>
                <span class="old-price">90 сом</span>
                <span class="price">65 сом</span>
            </div>

        </div>
    </section>

    <!-- Контакты -->
    <section id="contact">
        <h2>Контакты</h2>
        <p>📍 г. Бишкек</p>
        <p>📞 +996 550 721 020</p>
        <p>🕒 08:00 – 22:00</p>
    </section>

    <!-- Подвал -->
    <footer>
        <p>©️ 2026 Sweet Coffee | Все права защищены</p>
    </footer>

</body>
</html>
